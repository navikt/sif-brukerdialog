{
    "name": "@navikt/sif-brukerdialog",
    "version": "0.0.1",
    "private": true,
    "description": "Monorepo for felleskode og selvbetjeningsdialoger i Sykdom i familien",
    "bugs": {
        "url": "https://github.com/navikt/sif-brukerdialog/issues"
    },
    "repository": "https://github.com/navikt/sif-brukerdialog",
    "license": "MIT",
    "author": "NAV",
    "type": "module",
    "scripts": {
        "build": "turbo build",
        "build-storybook": "turbo build-storybook",
        "clean": "turbo clean",
        "clean:output": "node scripts/clean-output.mjs",
        "clean-all": "turbo clean && rm -rf node_modules",
        "codegen:dev": "turbo run codegen:dev",
        "codegen:prod": "turbo run codegen:prod",
        "deploy-gh-pages": "gh-pages -d gh-pages",
        "format": "prettier --write \"**/*.{ts,tsx,md}\"",
        "lint": "turbo lint",
        "lint:eslint": "turbo lint:eslint",
        "lint:fix": "turbo lint:fix",
        "lint:tsc": "turbo lint:tsc",
        "prepare": "husky install",
        "sort-package-json": "sort-package-json \"package.json\" \"apps/*/package.json\" \"apps-intern/*/package.json\" \"packages/*/package.json\" \"server*/package.json\"",
        "test": "turbo test"
    },
    "lint-staged": {
        "**/package.json": [
            "sort-package-json"
        ],
        "apps/**/*.{ts,tsx,js,jsx, css}": [
            "prettier --write"
        ],
        "packages/**/*.{ts,tsx,js,jsx, css}": [
            "prettier --write"
        ]
    },
    "dependencies": {
        "@changesets/cli": "2.31.0",
        "glob": "13.0.6",
        "tailwindcss": "4.3.1",
        "turbo": "2.9.18"
    },
    "devDependencies": {
        "@sif/eslint-config": "workspace:*",
        "config": "workspace:*",
        "gh-pages": "6.3.0",
        "husky": "9.1.7",
        "lint-staged": "17.0.7",
        "prettier": "3.8.4",
        "sort-package-json": "4.0.0",
        "typescript": "6.0.3",
        "vitest": "4.1.9"
    },
    "packageManager": "pnpm@10.33.4",
    "pnpm": {
        "overrides": {
            "brace-expansion@^5": ">=5.0.5",
            "js-yaml@3.13.1": "^3.14.2",
            "js-yaml@^4": ">=4.2.0",
            "jsdom": "28.1.0",
            "picomatch@^2": "^2.3.2",
            "picomatch@^4": "^4.0.4",
            "undici@^6": ">=6.26.0",
            "undici@^7": ">=7.28.0"
        }
    }
}
