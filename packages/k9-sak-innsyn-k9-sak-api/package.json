{
    "name": "@navikt/k9-sak-innsyn-k9-sak-api",
    "version": "0.2.15",
    "private": true,
    "repository": {
        "type": "git",
        "url": "git+https://github.com/navikt/sif-brukerdialog.git"
    },
    "type": "module",
    "main": "src/index.ts",
    "types": "src/index.ts",
    "scripts": {
        "codegen:dev": "CODEGEN_ENV=dev pnpm download-spec && pnpm openapi-ts && pnpm fix-regex",
        "codegen:prod": "CODEGEN_ENV=prod pnpm download-spec && pnpm openapi-ts && pnpm fix-regex",
        "download-spec": "node scripts/download-spec.mjs",
        "fix-regex": "node scripts/fix-generated-regex.mjs",
        "lint:eslint": "eslint './src/*/*.gen.ts'",
        "lint:fix": "eslint --quiet --fix './src/*/*.gen.ts'",
        "lint:tsc": "tsc --noEmit",
        "openapi-ts": "openapi-ts"
    },
    "devDependencies": {
        "@hey-api/openapi-ts": "0.98.2",
        "@sif/eslint-config": "workspace:*",
        "axios": "1.18.1",
        "config": "workspace:*",
        "eslint": "10.6.0",
        "postcss": "8.5.16",
        "prettier": "3.9.5",
        "typescript": "6.0.3",
        "vitest": "4.1.10",
        "zod": "4.4.3"
    },
    "peerDependencies": {
        "dayjs": "*",
        "uuid": "*"
    }
}
