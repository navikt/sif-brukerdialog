{
    "name": "@sif/soknad-ui",
    "version": "0.0.4",
    "private": true,
    "repository": {
        "type": "git",
        "url": "git+https://github.com/navikt/sif-brukerdialog.git"
    },
    "type": "module",
    "exports": {
        ".": "./src/index.ts",
        "./components": "./src/components/index.ts",
        "./lenker": "./src/lenker/index.ts",
        "./i18n": "./src/i18n/index.tsx",
        "./pages": "./src/pages/index.ts"
    },
    "main": "src/index.ts",
    "types": "src/index.ts",
    "scripts": {
        "build-storybook": "storybook build",
        "lint:eslint": "eslint \"./src/**/*.{js,ts,tsx}\"",
        "lint:fix": "eslint --quiet --fix './src/**/*.{js,ts,tsx}'",
        "lint:tsc": "tsc --noEmit",
        "storybook": "storybook dev -p 6006",
        "test": "vitest run"
    },
    "dependencies": {
        "@navikt/aksel-icons": "8.13.0",
        "@navikt/ds-react": "8.13.0",
        "@navikt/sif-common-env": "workspace:*",
        "@navikt/sif-common-hooks": "workspace:*",
        "@sif/api": "workspace:*",
        "@sif/utils": "workspace:*",
        "react-intl": "10.1.13",
        "react-responsive": "10.0.1"
    },
    "devDependencies": {
        "@navikt/ds-css": "8.13.0",
        "@sif/eslint-config": "workspace:*",
        "@storybook/addon-a11y": "10.4.6",
        "@storybook/addon-docs": "10.4.6",
        "@storybook/react-vite": "10.4.6",
        "@types/react": "19.2.17",
        "@types/react-dom": "19.2.3",
        "eslint-plugin-storybook": "10.4.6",
        "react": "19.2.7",
        "react-dom": "19.2.7",
        "storybook": "10.4.6",
        "typescript": "6.0.3",
        "vite": "8.0.16",
        "vitest": "4.1.9"
    },
    "peerDependencies": {
        "react": ">=19",
        "react-dom": ">=19"
    }
