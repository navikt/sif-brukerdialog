{
    "include": ["./node_modules/@sanity/base/types/**/*.ts", "./**/*.ts", "./**/*.tsx"],
    "compilerOptions": {
        "outDir": "build/dist",
        "module": "ESNext",
        "target": "ES2022",
        "lib": ["ES2022", "DOM"],
        "sourceMap": true,
        "allowJs": true,
        "jsx": "react-jsx",
        "moduleResolution": "bundler",
        "forceConsistentCasingInFileNames": true,
        "noImplicitReturns": true,
        "strict": true,
        "skipLibCheck": true,
        "noUnusedLocals": true,
        "types": ["node"]
    }
}
