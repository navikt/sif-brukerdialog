{
    "name": "@navikt/ung-brukerdialog-api",
    "main": "src/index.ts",
    "types": "src/index.ts",
    "private": true,
    "type": "module",
    "version": "0.0.4",
    "devDependencies": {
        "@hey-api/openapi-ts": "0.96.1",
        "@sif/eslint-config": "workspace:*",
        "axios": "1.15.1",
        "config": "workspace:*",
        "postcss": "8.5.10",
        "prettier": "*",
        "typescript": "6.0.3",
        "vitest": "4.1.4",
        "zod": "4.3.6"
    },
    "peerDependencies": {
        "dayjs": "*",
        "uuid": "*"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/navikt/sif-brukerdialog.git"
    },
    "scripts": {
        "fix-regexp": "node scripts/fix-generated-regex.mjs",
        "gen-types:fixed": "yarn gen-types && yarn fix-regexp",
        "gen-types": "openapi-ts -f openapi-ts.ung-brukerdialog-api.config.ts",
        "download-spec": "node scripts/download-spec.mjs",
        "codegen:dev": "CODEGEN_ENV=dev yarn download-spec && yarn gen-types:fixed",
        "codegen:prod": "CODEGEN_ENV=prod yarn download-spec && yarn gen-types:fixed",
        "lint:eslint": "eslint './src/ung-brukerdialog-api/client/*.gen.ts'",
        "lint:fix": "eslint --quiet --fix './src/ung-brukerdialog-api/client/*.gen.ts'",
        "lint:tsc": "tsc --noEmit"
    },
    "dependencies": {
        "@hey-api/client-axios": "0.9.1",
        "@hey-api/client-fetch": "0.13.1"
    }
}
