{
    "name": "@navikt/ung-brukerdialog-api",
    "version": "0.0.8",
    "private": true,
    "repository": {
        "type": "git",
        "url": "git+https://github.com/navikt/sif-brukerdialog.git"
    },
    "type": "module",
    "main": "src/index.ts",
    "types": "src/index.ts",
    "scripts": {
        "codegen:dev": "CODEGEN_ENV=dev pnpm download-spec && pnpm gen-types:fixed",
        "codegen:prod": "CODEGEN_ENV=prod pnpm download-spec && pnpm gen-types:fixed",
        "download-spec": "node scripts/download-spec.mjs",
        "fix-regexp": "node scripts/fix-generated-regex.mjs",
        "gen-types": "openapi-ts -f openapi-ts.ung-brukerdialog-api.config.ts",
        "gen-types:fixed": "pnpm gen-types && pnpm fix-regexp",
        "lint:eslint": "eslint './src/ung-brukerdialog-api/client/*.gen.ts'",
        "lint:fix": "eslint --quiet --fix './src/ung-brukerdialog-api/client/*.gen.ts'",
        "lint:tsc": "tsc --noEmit"
    },
    "devDependencies": {
        "@hey-api/openapi-ts": "0.98.2",
        "@navikt/sif-common-env": "workspace:*",
        "@sif/eslint-config": "workspace:*",
        "axios": "1.18.1",
        "config": "workspace:*",
        "eslint": "10.6.0",
        "postcss": "8.5.15",
        "prettier": "3.8.5",
        "typescript": "6.0.3",
        "vitest": "4.1.9",
        "zod": "4.4.3"
    },
    "peerDependencies": {
        "dayjs": "*",
        "uuid": "*"
    }
}
