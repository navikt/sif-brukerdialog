{
    "name": "@navikt/k9-sak-innsyn-api",
    "version": "0.2.18",
    "private": true,
    "repository": {
        "type": "git",
        "url": "git+https://github.com/navikt/sif-brukerdialog.git"
    },
    "type": "module",
    "main": "src/index.ts",
    "types": "src/index.ts",
    "scripts": {
        "codegen:dev": "CODEGEN_ENV=dev pnpm download-spec && pnpm gen-types:all:fixed",
        "codegen:prod": "CODEGEN_ENV=prod pnpm download-spec && pnpm gen-types:all:fixed",
        "download-spec": "node scripts/download-spec.mjs",
        "fix-regex": "node scripts/fix-generated-regex.mjs",
        "gen-types:all": "pnpm gen-types:innsyn &&  pnpm gen-types:k9-sak && pnpm gen-types:legacy",
        "gen-types:all:fixed": "pnpm gen-types:all && pnpm fix-regex",
        "gen-types:innsyn": "openapi-ts --file configs/openapi-ts.config-innsyn.ts",
        "gen-types:k9-sak": "openapi-ts --file configs/openapi-ts.config-k9-sak.ts",
        "gen-types:legacy": "openapi-ts --file configs/openapi-ts.config.ts",
        "lint:eslint": "eslint './src/*/*.gen.ts'",
        "lint:fix": "eslint --quiet --fix './src/generated/*/*.gen.ts'",
        "lint:tsc": "tsc --noEmit"
    },
    "devDependencies": {
        "@hey-api/openapi-ts": "0.98.2",
        "@sif/eslint-config": "workspace:*",
        "axios": "1.18.0",
        "config": "workspace:*",
        "postcss": "8.5.15",
        "prettier": "3.8.4",
        "typescript": "6.0.3",
        "vitest": "4.1.9",
        "zod": "4.4.3"
    },
    "peerDependencies": {
        "dayjs": "*",
        "uuid": "*"
    }
}
