{
    "extends": "../config/tsconfig-packages.json",
    "compilerOptions": {
        "rootDir": "./src",
        "baseUrl": "./src",
        "paths": {
            "@ui/components/*": ["components/*"],
            "@ui/i18n": ["i18n/index.tsx"],
            "@ui/i18n/*": ["i18n/*"],
            "@ui/modules/*": ["modules/*"],
            "@ui/utils/*": ["utils/*"]
        }
    },

    "include": ["src/**/*", "depr"],
    "exclude": ["node_modules"]
}
