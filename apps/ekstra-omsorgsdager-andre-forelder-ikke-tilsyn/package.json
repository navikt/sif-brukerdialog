{
    "name": "@navikt/ekstra-omsorgsdager-andre-forelder-ikke-tilsyn",
    "version": "1.35.79",
    "private": true,
    "description": "Søknad om ekstra omsorgsdager når den andre forelderen ikke kan ha tilsyn med barn",
    "homepage": "https://github.com/navikt/sif-brukerdialog#readme",
    "bugs": {
        "url": "https://github.com/navikt/sif-brukerdialog/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/navikt/sif-brukerdialog.git"
    },
    "license": "MIT",
    "author": {
        "name": "NAV"
    },
    "type": "module",
    "scripts": {
        "build": "vite build --base=/familie/sykdom-i-familien/soknad/ekstra-omsorgsdager-andre-forelder-ikke-tilsyn",
        "build-storybook": "storybook build",
        "clean": "rm -rf node_modules dist",
        "dev": "vite --config vite.dev.config.ts",
        "lint:eslint": "npx eslint \"./src/**/*.{js,ts,tsx}\"",
        "lint:fix": "npx eslint --quiet --fix './src/**/*.{js,ts,tsx}' './*.{ts,tsx}' './playwright/**/*.{js,ts,tsx}' './mock/**/*.{js,ts,tsx}'",
        "lint:tsc": "tsc --noEmit",
        "playwright-test": "playwright test",
        "pw:build": "vite build --config vite.playwright.config.ts",
        "pw:run": "pnpm playwright-test",
        "pw:start": "vite preview --base / --config vite.playwright.config.ts",
        "storybook": "storybook dev -p 6006",
        "test": "vitest run"
    },
    "eslintConfig": {
        "overrides": [
            {
                "files": [
                    "**/*.stories.*"
                ],
                "rules": {
                    "import/no-anonymous-default-export": "off"
                }
            }
        ]
    },
    "dependencies": {
        "@navikt/aksel-icons": "8.13.0",
