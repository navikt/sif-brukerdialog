{
    "name": "@navikt/ungdomsytelse-deltaker",
    "version": "1.5.57",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build --base=/ungdomsprogrammet/ytelsen",
        "check:types": "tsc --noemit",
        "clean": "rm -rf node_modules dist dist-demo",
        "demo:build": "run-s demo:build-app demo:copy-app-files",
        "demo:build-app": "vite build --config vite.demo.config.ts",
        "demo:copy-app-files": "cp ./dist-demo/demo/index.html ./dist-demo/index.html && rm -rf ./dist-demo/demo && cp ./mockServiceWorker.js ./dist-demo/",
        "demo:start": "vite preview --base /ungdomsprogrammet/ytelsen/ --config vite.demo.config.ts",
        "dev": "pnpm dev:vite",
        "dev:debug": "vite --debug",
        "dev:vite": "vite --base=/ungdomsprogrammet/ytelsen --config vite.dev.config.ts",
        "gh-pages:clean": "rm -rf ../../docs/ungdomsytelse-deltaker",
        "gh-pages:copy": "cp -r ./dist-demo ../../docs/ungdomsytelse-deltaker",
        "gh-pages:rebuild": "run-s demo:build gh-pages:clean gh-pages:copy",
        "lint:eslint": "eslint src",
        "lint:fix": "eslint src --fix",
        "playwright-test": "playwright test",
        "pw:build": "run-s pw:build-app demo:copy-app-files",
        "pw:build-app": "vite build --config vite.playwright.config.ts",
        "pw:run": "pnpm playwright-test",
        "pw:start": "vite preview --base /ungdomsprogrammet/ytelsen/ --config vite.playwright.config.ts",
        "storybook": "storybook dev -p 6006",
        "build-storybook": "storybook build",
        "test": "vitest run"
    },
    "dependencies": {
        "@grafana/faro-react": "2.7.0",
