{
    "extends": "../../packages/config/tsconfig-apps.json",
    "compilerOptions": {
        "outDir": "build/dist",
        "typeRoots": ["../../node_modules/@types", "./node_modules/@types"],
        "baseUrl": "./",
        "paths": {
            "@rammeverk/*": ["src/rammeverk/*"],
            "@app/*": ["src/app/*"],
            "@common/*": ["src/common/*"]
        }
    },
    "exclude": ["node_modules", "dist", "**.js"],
    "include": ["./src/**/*", "./mock/**/*", "./vite-env.d.ts", "./tailwind.config.ts"]
}
