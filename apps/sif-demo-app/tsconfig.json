{
    "extends": "../../packages/config/tsconfig-apps.json",
    "compilerOptions": {
        "outDir": "build/dist",
        "paths": {
            "@app/*": ["./src/app/*"],
            "vite": ["../../node_modules/vite"]
        }
    },
    "exclude": ["node_modules", "dist", "**.js"],
    "include": [
        "./src/**/*",
        "./mock/**/*",
        "./playwright/**/*",
        "./playwright.config.ts",
        "./vite.e2e.config.ts",
        "./vite-env.d.ts",
        "./tailwind.config.ts",
        "./vite.config.ts",
        "./vite.dev.config.ts",
        "env.schema.ts"
    ]
}
