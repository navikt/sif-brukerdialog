{
    "name": "@navikt/sif-demo-app",
    "type": "module",
    "private": true,
    "version": "0.0.2",
    "scripts": {
        "dev": "vite --base=/sif-demo --config vite.dev.config.ts",
        "pw:dev": "vite --config vite.e2e.config.ts",
