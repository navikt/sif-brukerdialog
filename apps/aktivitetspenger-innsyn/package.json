{
    "name": "@navikt/aktivitetspenger-innsyn",
    "version": "0.0.12",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build --base=/aktivitetspenger/innsyn",
        "build-storybook": "storybook build",
        "check:types": "tsc --noemit",
        "clean": "rm -rf node_modules dist dist-demo",
        "demo:build": "vite build --config vite.demo.config.ts",
        "dev": "vite --base=/aktivitetspenger/innsyn --config vite.dev.config.ts",
        "gh-pages:clean": "rm -rf ../../docs/aktivitetspenger-innsyn",
        "gh-pages:copy": "cp -r ./dist-demo ../../docs/aktivitetspenger-innsyn",
        "gh-pages:rebuild": "pnpm demo:build && pnpm gh-pages:clean && pnpm gh-pages:copy",
        "lint:eslint": "eslint src",
        "lint:fix": "eslint src --fix",
        "pw:dev": "vite --config vite.e2e.config.ts",
        "pw:run": "playwright test",
        "pw:run:headed": "playwright test --headed",
        "storybook": "storybook dev -p 6006",
        "test": "vitest run"
    },
